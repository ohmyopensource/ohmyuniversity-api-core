# ================================
# OhMyUniversity! - Core - .env.example
# ================================

# Spring profile: dev | prod | test
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (db_core)
POSTGRES_URL=jdbc:postgresql://localhost:5432/db_core
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

# Redis (shared with gateway)
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=redis

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# JWT
JWT_SECRET=omu_dev_jwt_secret_change_in_production_please
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
